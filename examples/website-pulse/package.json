  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@vixeq/core": "workspace:*",
    "@vixeq/player-react": "workspace:*",
    "@vixeq/react": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6"
  }
}
