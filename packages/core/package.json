{
  "name": "@vixeq/core",
  "version": "0.8.0-beta.1",
  "type": "module",
  "description": "A UI-agnostic step sequencer engine for 0-1 control values.",
  "license": "MIT",
  "homepage": "https://github.com/kramhash/vixeq#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kramhash/vixeq.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/kramhash/vixeq/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dom": {
      "types": "./dist/dom.d.ts",
      "import": "./dist/dom.js",
      "require": "./dist/dom.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "sequencer",
    "step-sequencer",
    "bpm",
    "clock",
    "control-signal",
    "automation"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/dom.ts --format esm,cjs --dts --sourcemap",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
