{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["vite/client"]
  },
  // vite.config.ts is intentionally excluded: `vite build` (the smoke:vite
  // step) loads it via esbuild without type-checking, and @vitejs/plugin-react's
  // own .d.ts uses syntax that TypeScript 5.5 (the spec's minimum supported
  // version, exercised via SMOKE_TS_VERSION=5.5) can't parse. That's a floor
  // on the dev-tooling dependency, not on @vixeq's published types, so it's
  // out of scope for this type-check.
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
